{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",

  "agents": {
    "sisyphus": {
      "model": "opencode-go/deepseek-v4-flash",
      "fallback_models": [
        "opencode-go/minimax-m3",
        "opencode-go/deepseek-v4-pro"
      ]
    },
    "prometheus": {
      "model": "opencode-go/glm-5",
      "fallback_models": [
        "opencode-go/kimi-k2.6",
        "opencode-go/deepseek-v4-pro"
      ]
    },

    "oracle": {
      "model": "opencode-go/deepseek-v4-flash",
      "fallback_models": [
        "opencode-go/kimi-k2.6",
        "opencode-go/glm-5"
      ]
    },

    "hephaestus": {
      "model": "opencode-go/deepseek-v4-pro",
      "fallback_models": [
        "opencode-go/kimi-k2.6"
      ]
    },


    "explore": {
      "model": "opencode-go/deepseek-v4-flash",
      "fallback_models": [
        "opencode-go/qwen3.5-plus",  
        "opencode-go/minimax-m2.5"
      ]
    },

    "librarian": {
      "model": "opencode-go/minimax-m2.7",
      "fallback_models": [
        "opencode-go/deepseek-v4-flash",
        "opencode-go/qwen3.5-plus"
      ]
    },

    "atlas": {
      "model": "opencode-go/deepseek-v4-flash",
      "fallback_models": [
        "opencode-go/glm-5",
        "opencode-go/minimax-m2.7"
      ]
    },

    "metis": {
      "model": "opencode-go/deepseek-v4-flash",
      "fallback_models": [
        "opencode-go/kimi-k2.6",
        "opencode-go/deepseek-v4-pro"
      ]
    },

    "momus": {
      "model": "opencode-go/deepseek-v4-pro",
      "fallback_models": [
        "opencode-go/kimi-k2.6"
      ]
    }
  },

  "categories": {
    "unspecified-high": {
      "model": "opencode-go/deepseek-v4-flash",
      "fallback_models": [
        "opencode-go/deepseek-v4-pro",
        "opencode-go/glm-5"
      ]
    },


    "deep": {
      "model": "opencode-go/deepseek-v4-pro",
      "fallback_models": [
        "opencode-go/kimi-k2.6",
        "opencode-go/glm-5"
      ]
    },

    "visual-engineering": {
      "model": "opencode-go/mimo-v2.5",
      "fallback_models": [
        "opencode-go/kimi-k2.6",    
        "opencode-go/glm-5"
      ]
    },

    "ultrabrain": {
      "model": "opencode-go/deepseek-v4-pro",
      "fallback_models": [
        "opencode-go/kimi-k2.6"
      ]
    },

    "quick": {
      "model": "opencode-go/deepseek-v4-flash",
      "fallback_models": [
        "opencode-go/qwen3.5-plus",
        "opencode-go/minimax-m2.5"
      ]
    },


    "unspecified-low": {
      "model": "opencode-go/qwen3.5-plus",
      "fallback_models": [
        "opencode-go/deepseek-v4-flash",
        "opencode-go/minimax-m2.5"
      ]
    },

    "writing": {
      "model": "opencode-go/minimax-m2.5",
      "fallback_models": [
        "opencode-go/qwen3.5-plus",
        "opencode-go/deepseek-v4-flash"
      ]
    },

    "artistry": {
      "model": "opencode-go/kimi-k2.5",
      "fallback_models": [
        "opencode-go/glm-5"
      ]
    }
  },


  "background_task": {
    "defaultConcurrency": 5,
    "providerConcurrency": {
      "opencode-go": 5
    },
    "modelConcurrency": {
      "opencode-go/kimi-k2.6": 3,
      "opencode-go/deepseek-v4-pro": 3,
      "opencode-go/deepseek-v4-flash": 8,  
      "opencode-go/qwen3.5-plus": 6,
      "opencode-go/minimax-m2.5": 6
    }
  },

  "experimental": {
    "aggressive_truncation": true
  }
}

{
  "openapi": "3.1.0",
  "info": {
    "title": "MCPForge API",
    "description": "Convert OpenAPI specs into AI-optimized MCP servers",
    "version": "0.1.0"
  },
  "paths": {
    "/api/v1/auth/register": {

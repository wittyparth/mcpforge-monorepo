{
  "name": "mcpforge-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "MCPForge — convert any OpenAPI spec to an AI-optimized MCP server in under 60 seconds",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:api": "turbo run dev --filter=@mcpforge/api",
    "dev:web": "turbo run dev --filter=@mcpforge/web",

    "dev:up": "./scripts/dev.sh",
    "dev:up:build": "./scripts/dev.sh --build",
    "dev:stop": "./scripts/dev.sh --stop",

    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore",
    "clean": "turbo run clean && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.9"
}

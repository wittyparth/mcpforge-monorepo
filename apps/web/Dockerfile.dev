# syntax=docker/dockerfile:1.7
# ──────────────────────────────────────────────────────────────────
# Dockerfile.dev — Next.js frontend (development mode)
# ──────────────────────────────────────────────────────────────────
# Uses turbopack for fast refresh. Mounts src/ and public/ as volumes
# so changes reflect immediately. The build context is the monorepo
# root (required for pnpm workspace resolution).
# ──────────────────────────────────────────────────────────────────
FROM node:22-slim AS base

RUN corepack enable && pnpm --version

WORKDIR /app

# ── Install dependencies (layer cache-friendly) ──────────────────
# Copy workspace manifests first to leverage Docker layer caching
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig.base.json turbo.json ./

# Copy all workspace package manifests (required by pnpm --filter)
COPY apps/web/package.json ./apps/web/
COPY packages/shared-types/ ./packages/shared-types/
COPY packages/tsconfig/ ./packages/tsconfig/
COPY packages/eslint-config/ ./packages/eslint-config/

# Install — frozen-lockfile ensures CI-grade reproducibility
RUN pnpm install --frozen-lockfile

# ── Copy remaining source ────────────────────────────────────────
# In dev mode the src/ and public/ dirs are overlaid via volume mount
# (see docker-compose.yml). This COPY is for the Docker layer to have
# the source available at build time (e.g., for type-check on start).
COPY apps/web/ ./apps/web/

EXPOSE 3000

# Turbopack for instant Fast Refresh, host 0.0.0.0 for Docker
CMD ["pnpm", "--filter", "@mcpforge/web", "dev"]

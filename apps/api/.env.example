# MCPForge API — Environment Configuration
# Copy this to .env and fill in your values.

# Runtime
ENVIRONMENT=development
LOG_LEVEL=INFO
API_VERSION=0.1.0

# Database (PostgreSQL via asyncpg)
# For Neon free tier: postgresql+asyncpg://user:pass@ep-xxx.us-east-2.aws.neon.tech/mcpforge?sslmode=require
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mcpforge

# Redis (redis.asyncio compatible)
# For Upstash free tier: rediss://default:pass@us1-xxx.upstash.io:6379
REDIS_URL=redis://localhost:6379/0

# JWT
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-min-32-characters-long-dev-only-do-not-use-in-prod
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# Encryption (Fernet master key for credentials at rest)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave empty in dev to use a process-local dev key (data cannot be decrypted after restart).
ENCRYPTION_KEY=

# CSRF (auto-derived from JWT_SECRET if unset)
CSRF_SECRET=

# Rate limiting (per IP, per minute)
RATE_LIMIT_PER_IP_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_IP_PER_MINUTE=5

# Account lockout
LOCKOUT_MAX_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# HIBP (Have I Been Pwned) — disable in dev/test if you have no internet
HIBP_ENABLED=true
HIBP_API_URL=https://api.pwnedpasswords.com/range

# GitHub OAuth (optional, F7)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=

# LLM provider (OpenAI-compatible, primary = DeepSeek via opencode-go)
LLM_PROVIDER=opencode-go
LLM_BASE_URL=https://opencode.ai/zen/go/v1
LLM_MODEL=deepseek-v4-flash
LLM_API_KEY=
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.0
LLM_TIMEOUT_SECONDS=60
LLM_RETRY_ATTEMPTS=3
LLM_PROMPT_CACHING_ENABLED=true
LLM_JSON_MODE=true

# Cost guardrails
MAX_AI_CREDITS_PER_USER_PER_DAY=100
MAX_SPEC_SIZE_BYTES=5242880
MAX_SPEC_FETCH_TIMEOUT_SECONDS=10

# Email (Resend — Phase 1.1)
EMAIL_PROVIDER_API_KEY=
EMAIL_FROM_ADDRESS=noreply@mcpforge.io

# Stripe (Phase 1.1)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_LITIGATED_MODE=false

# AWS S3 (object storage for OpenAPI specs and other files)
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# Optional: override endpoint for S3-compatible services (leave empty for AWS)
AWS_S3_ENDPOINT_URL=

# Sentry (Wave 0 error tracking)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

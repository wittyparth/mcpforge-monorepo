# MCPForge API — Environment Configuration
# Copy this to .env and fill in your values.

# Runtime
ENVIRONMENT=development
LOG_LEVEL=INFO

# Database (PostgreSQL via asyncpg)
# For Neon free tier: postgresql+asyncpg://user:pass@ep-xxx.us-east-2.aws.neon.tech/mcpforge?sslmode=require
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mcpforge

# Redis (redis.asyncio compatible)
# For Upstash free tier: rediss://default:pass@us1-xxx.upstash.io:6379
REDIS_URL=redis://localhost:6379/0

# JWT
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-min-32-characters-long
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# GitHub OAuth (optional, for Phase 2)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# AI (placeholder, for Phase 3)
ANTHROPIC_API_KEY=

# MCPForge Local Dev Stack — Environment
# Copy this file to `.env` and fill in your real secrets. The committed
# values are safe defaults; the secrets in `secrets:` are placeholders.
#
# This file is loaded by docker-compose.yml via `env_file:`. DO NOT commit
# `.env` (it's in .gitignore). Only `.env.example` is tracked.

# ── Local infra (used by docker-compose service names) ────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/mcpforge
REDIS_URL=redis://redis:6379/0
JWT_SECRET=dev-only-jwt-secret-please-change-in-prod-min-32-chars

# ── Frontend (Next.js — NEXT_PUBLIC_* are inlined at build time) ──────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── LLM provider (OpenAI-compatible) ─────────────────────────────────
LLM_PROVIDER=opencode-go
LLM_BASE_URL=https://opencode.ai/zen/go/v1
LLM_MODEL=deepseek-v4-flash
# Set this to your real LLM key for local AI features to work
LLM_API_KEY=

# ── GitHub OAuth (optional — needed for "Login with GitHub") ─────────
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/github/callback

# ── Email (Resend — used for password reset, verification) ──────────
EMAIL_PROVIDER_API_KEY=
EMAIL_FROM_ADDRESS=MCPForge <noreply@example.com>

# ── Stripe (Phase 1.1 — leave empty for now) ────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_LITIGATED_MODE=true
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly_dev
STRIPE_PRICE_PRO_YEARLY=price_pro_yearly_dev
STRIPE_PRICE_TEAM_SEAT_MONTHLY=price_team_seat_dev

# ── AWS S3 (object storage for OpenAPI specs) ───────────────────────
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_ENDPOINT_URL=
